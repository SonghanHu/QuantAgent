# Copy to `.env` and fill in values. Never commit `.env`.
#   cp .env.example .env

# --- OpenAI-compatible APIs ---
OPENAI_API_KEY=...
# Optional: custom base URL (Azure, proxy, local gateway, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=...

# Small / fast model for parsing, decomposition, routing
OPENAI_SMALL_MODEL=gpt-5.4-nano

# Agent run log (SQLite). Default: ./data/agent.db
# AGENT_DB_PATH=./data/agent.db

# --- Optional: defaults for your agent / scripts ---
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# REQUEST_TIMEOUT_SEC=60
