# Copy to `.env` and fill in values. Never commit `.env`.
#   cp .env.example .env

# --- OpenAI-compatible APIs ---
OPENAI_API_KEY=...
# Optional: custom base URL (Azure, proxy, local gateway, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- Anthropic ---
ANTHROPIC_API_KEY=...

# Small / fast model for parsing, decomposition, routing
OPENAI_SMALL_MODEL=gpt-5.4-nano

# Agent run log (SQLite). Default: ./data/agent.db
# AGENT_DB_PATH=./data/agent.db

# Run debug agent after each failed subtask (writes debug_notes.json + WS event)
# DEBUG_AGENT_ON_FAILURE=1

# Post-subtask “thinking” (LLM: next tools to consider). Disable with STEP_THINKING=0
# STEP_THINKING=1

# --- Optional: defaults for your agent / scripts ---
# OPENAI_MODEL=gpt-4o-mini
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# REQUEST_TIMEOUT_SEC=60
